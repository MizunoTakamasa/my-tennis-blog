---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';

type Props = CollectionEntry<'blog'>['data'];

const { title, description, pubDate, updatedDate, heroImage } = Astro.props;
---

<html lang="ja">
  <head>
    <BaseHead title={title} description={description} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Oswald:wght@700&family=Noto+Sans+JP:wght@400;700;900&display=swap" rel="stylesheet" />
  </head>

  <body>
    <style is:global>
      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

      body {
        background: #0a0a0a !important;
        color: #d8d8d8 !important;
        font-family: 'Noto Sans JP', sans-serif !important;
        overflow-x: hidden;
        width: 100% !important;
        max-width: 100% !important;
      }

      body > main, main {
        width: 100% !important;
        max-width: 100% !important;
        margin: 0 !important;
        padding: 0 !important;
      }

      /* ===== 記事ヘッダー ===== */
      .ap-header {
        position: relative;
        width: 100vw;
        margin-left: calc(50% - 50vw);
        padding: 5rem 2rem 3.5rem;
        display: flex;
        flex-direction: column;
        align-items: center;
        text-align: center;
        overflow: hidden;
        border-bottom: 1px solid rgba(200,255,80,0.15);
      }

      /* 薄いグリッド */
      .ap-header::before {
        content: '';
        position: absolute;
        inset: 0;
        background-image:
          linear-gradient(rgba(255,255,255,0.025) 1px, transparent 1px),
          linear-gradient(90deg, rgba(255,255,255,0.025) 1px, transparent 1px);
        background-size: 60px 60px;
        pointer-events: none;
        z-index: 0;
      }

      /* 左上アクセントライン */
      .ap-header::after {
        content: '';
        position: absolute;
        top: 0; left: 0;
        width: 180px; height: 3px;
        background: linear-gradient(90deg, #c8ff50, transparent);
      }

      /* 右下アクセントライン */
      .ap-corner {
        position: absolute;
        bottom: 0; right: 0;
        width: 120px; height: 3px;
        background: linear-gradient(270deg, rgba(200,255,80,0.4), transparent);
        z-index: 1;
      }

      /* 薄いリング装飾 */
      .ap-ring {
        position: absolute;
        border-radius: 50%;
        pointer-events: none;
        border: 1px solid rgba(200,255,80,0.08);
        z-index: 0;
        animation: apRing 30s linear infinite;
      }
      .ap-ring-1 { width: 400px; height: 400px; top: -160px; right: -80px; }
      .ap-ring-2 { width: 200px; height: 200px; bottom: -80px; left: -60px; animation-direction: reverse; animation-duration: 22s; }
      @keyframes apRing {
        from { transform: rotate(0deg); }
        to   { transform: rotate(360deg); }
      }

      .ap-header-inner {
        position: relative;
        z-index: 2;
        max-width: 760px;
        width: 100%;
      }

      /* カテゴリバッジ */
      .ap-cat {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        font-size: 0.62rem;
        letter-spacing: 0.32em;
        text-transform: uppercase;
        color: #c8ff50;
        border: 1px solid rgba(200,255,80,0.35);
        padding: 5px 14px;
        border-radius: 99px;
        margin-bottom: 1.5rem;
        opacity: 0;
        animation: apFade 0.6s ease 0.1s forwards;
      }
      .ap-cat-dot {
        width: 5px; height: 5px;
        border-radius: 50%;
        background: #c8ff50;
        animation: apPulse 2s ease-in-out infinite;
      }
      @keyframes apPulse {
        0%, 100% { opacity: 1; transform: scale(1); }
        50%       { opacity: 0.4; transform: scale(0.7); }
      }

      /* タイトル */
      .ap-title {
        font-family: 'Noto Sans JP', sans-serif;
        font-weight: 900;
        font-size: clamp(1.8rem, 5vw, 3.2rem);
        line-height: 1.2;
        color: #f5f5f5;
        letter-spacing: -0.01em;
        opacity: 0;
        animation: apFade 0.7s ease 0.2s forwards;
      }

      /* 日付 */
      .ap-meta {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 1.5rem;
        margin-top: 1.5rem;
        flex-wrap: wrap;
        opacity: 0;
        animation: apFade 0.7s ease 0.32s forwards;
      }
      .ap-date {
        font-size: 0.72rem;
        color: rgba(240,240,240,0.3);
        letter-spacing: 0.12em;
        text-transform: uppercase;
      }
      .ap-updated {
        font-size: 0.7rem;
        color: rgba(200,255,80,0.5);
        font-style: italic;
        letter-spacing: 0.08em;
      }
      .ap-divider-dot {
        width: 3px; height: 3px;
        border-radius: 50%;
        background: rgba(240,240,240,0.2);
      }

      @keyframes apFade {
        from { opacity: 0; transform: translateY(16px); }
        to   { opacity: 1; transform: translateY(0); }
      }

      /* ===== ヒーロー画像 ===== */
      .ap-hero-img {
        width: 100vw;
        margin-left: calc(50% - 50vw);
        max-height: 420px;
        overflow: hidden;
        position: relative;
      }
      .ap-hero-img img {
        width: 100%;
        height: 420px;
        object-fit: cover;
        display: block;
        filter: brightness(0.85) saturate(0.9);
      }
      .ap-hero-img::after {
        content: '';
        position: absolute;
        bottom: 0; left: 0; right: 0;
        height: 120px;
        background: linear-gradient(to bottom, transparent, #0a0a0a);
      }

      /* ===== 記事本文エリア ===== */
      .ap-body {
        max-width: 720px;
        margin: 0 auto;
        padding: 3.5rem 1.5rem 5rem;
      }

      /* ===== Prose スタイル ===== */
      .ap-prose {
        line-height: 1.9;
        font-size: 1rem;
        color: rgba(220,220,220,0.85);
      }

      .ap-prose h1,
      .ap-prose h2,
      .ap-prose h3,
      .ap-prose h4 {
        font-family: 'Noto Sans JP', sans-serif;
        font-weight: 900;
        color: #f0f0f0;
        margin: 2.5rem 0 1rem;
        line-height: 1.3;
        letter-spacing: -0.01em;
      }
      .ap-prose h2 {
        font-size: 1.45rem;
        padding-left: 1rem;
        border-left: 3px solid #c8ff50;
        position: relative;
      }
      .ap-prose h3 {
        font-size: 1.15rem;
        color: #c8ff50;
      }

      .ap-prose p { margin: 1.25rem 0; }

      .ap-prose strong {
        color: #f0f0f0;
        font-weight: 700;
      }

      .ap-prose em {
        color: rgba(200,255,80,0.8);
        font-style: normal;
      }

      .ap-prose a {
        color: #c8ff50;
        text-decoration: underline;
        text-decoration-color: rgba(200,255,80,0.35);
        transition: text-decoration-color 0.2s;
      }
      .ap-prose a:hover { text-decoration-color: #c8ff50; }

      .ap-prose ul,
      .ap-prose ol {
        padding-left: 1.5rem;
        margin: 1.25rem 0;
      }
      .ap-prose li {
        margin: 0.5rem 0;
        color: rgba(220,220,220,0.8);
      }
      .ap-prose li::marker { color: #c8ff50; }

      .ap-prose blockquote {
        border-left: 3px solid rgba(200,255,80,0.4);
        padding: 1rem 1.5rem;
        margin: 2rem 0;
        background: rgba(200,255,80,0.04);
        border-radius: 0 4px 4px 0;
        color: rgba(220,220,220,0.7);
        font-style: italic;
      }

      .ap-prose code {
        background: #1a1a1a;
        border: 1px solid rgba(200,255,80,0.15);
        border-radius: 3px;
        padding: 0.15em 0.4em;
        font-size: 0.88em;
        color: #c8ff50;
      }

      .ap-prose pre {
        background: #111;
        border: 1px solid rgba(200,255,80,0.12);
        border-radius: 4px;
        padding: 1.5rem;
        overflow-x: auto;
        margin: 2rem 0;
      }
      .ap-prose pre code {
        background: none;
        border: none;
        padding: 0;
        font-size: 0.88rem;
      }

      .ap-prose hr {
        border: none;
        border-top: 1px solid rgba(200,255,80,0.15);
        margin: 2.5rem 0;
      }

      .ap-prose img {
        width: 100%;
        border-radius: 4px;
        margin: 2rem 0;
        filter: brightness(0.9) saturate(0.9);
      }

      /* ===== 区切り線（記事下） ===== */
      .ap-footer-line {
        width: 100vw;
        margin-left: calc(50% - 50vw);
        height: 1px;
        background: linear-gradient(90deg, transparent, rgba(200,255,80,0.2) 30%, rgba(200,255,80,0.2) 70%, transparent);
      }

      /* ===== 戻るリンク ===== */
      .ap-back {
        width: 100vw;
        margin-left: calc(50% - 50vw);
        padding: 2rem clamp(1.5rem, 6vw, 6rem);
        display: flex;
        align-items: center;
        justify-content: space-between;
        flex-wrap: wrap;
        gap: 1rem;
        background: #0d0d0d;
        border-top: 1px solid rgba(255,255,255,0.04);
      }

      .ap-back-btn {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        font-size: 0.78rem;
        font-weight: 700;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        text-decoration: none;
        color: rgba(240,240,240,0.5);
        transition: color 0.2s;
      }
      .ap-back-btn:hover { color: #c8ff50; }
      .ap-back-btn .arrow { transition: transform 0.2s; }
      .ap-back-btn:hover .arrow { transform: translateX(-4px); }

      .ap-back-logo {
        font-family: 'Oswald', sans-serif;
        font-size: 0.9rem;
        color: rgba(200,255,80,0.4);
        letter-spacing: 0.2em;
        text-transform: uppercase;
      }
    </style>

    <Header />
    <main>
      <article>

        <!-- ヘッダー -->
        <div class="ap-header">
          <div class="ap-ring ap-ring-1"></div>
          <div class="ap-ring ap-ring-2"></div>
          <div class="ap-corner"></div>
          <div class="ap-header-inner">
            <span class="ap-cat">
              <span class="ap-cat-dot"></span>
              Tennis Practice Notes
            </span>
            <h1 class="ap-title">{title}</h1>
            <div class="ap-meta">
              <span class="ap-date"><FormattedDate date={pubDate} /></span>
              {updatedDate && (
                <>
                  <span class="ap-divider-dot"></span>
                  <span class="ap-updated">Updated: <FormattedDate date={updatedDate} /></span>
                </>
              )}
            </div>
          </div>
        </div>

        <!-- ヒーロー画像 -->
        {heroImage && (
          <div class="ap-hero-img">
            <Image width={1020} height={420} src={heroImage} alt="" />
          </div>
        )}

        <!-- 本文 -->
        <div class="ap-body">
          <div class="ap-prose">
            <slot />
          </div>
        </div>

      </article>

      <!-- フッター区切り -->
      <div class="ap-footer-line"></div>

      <!-- 戻るリンク -->
      <div class="ap-back">
        <a href="/blog" class="ap-back-btn">
          <span class="arrow">←</span> 記事一覧に戻る
        </a>
        <span class="ap-back-logo">Tennis Blog</span>
      </div>

    </main>
    <Footer />
  </body>
</html>
