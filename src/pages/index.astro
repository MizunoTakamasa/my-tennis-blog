---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---
<html lang="ja">
  <head>
    <BaseHead title="テニス練習メモ" description="テニスの練習メモブログ" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Oswald:wght@700&family=Noto+Sans+JP:wght@400;700;900&display=swap" rel="stylesheet" />
  </head>
  <body>
    <style is:global>
      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

      body {
        background: #0a0a0a !important;
        color: #f0f0f0 !important;
        font-family: 'Noto Sans JP', sans-serif !important;
        overflow-x: hidden;
        width: 100% !important;
        max-width: 100% !important;
      }

      body > main, main {
        width: 100% !important;
        max-width: 100% !important;
        margin: 0 !important;
        padding: 0 !important;
      }

      /* ===== HERO ===== */
      .t-hero {
        position: relative;
        width: 100vw;
        margin-left: calc(50% - 50vw);
        min-height: 92vh;
        display: flex !important;
        align-items: center !important;
        justify-content: center !important;
        overflow: hidden;
        padding: 5rem 1rem 4rem;
      }

      /* Canvas（背景アニメーション） */
      #tennis-canvas {
        position: absolute;
        inset: 0;
        width: 100%;
        height: 100%;
        z-index: 0;
      }

      /* ネットライン */
      .t-netline {
        position: absolute;
        bottom: 0; left: 50%;
        transform: translateX(-50%);
        width: 90%;
        height: 2px;
        background: #c8ff50;
        box-shadow: 0 0 20px rgba(200,255,80,0.6);
        z-index: 1;
      }

      /* 回転サークル */
      .t-ring {
        position: absolute;
        border-radius: 50%;
        pointer-events: none;
        z-index: 1;
      }
      .t-ring-1 {
        width: 500px; height: 500px;
        top: -150px; right: -100px;
        border: 1.5px solid rgba(200,255,80,0.15);
        animation: tRing 25s linear infinite;
      }
      .t-ring-2 {
        width: 300px; height: 300px;
        bottom: 20px; left: -80px;
        border: 1px solid rgba(255,255,255,0.06);
        animation: tRing 18s linear infinite reverse;
      }
      @keyframes tRing { from { transform: rotate(0deg); } to { transform: rotate(360deg); } }

      /* ===== ヒーローテキスト ===== */
      .t-content {
        position: relative;
        z-index: 10;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        text-align: center;
        width: 100%;
        max-width: 800px;
        margin: 0 auto;
      }

      .t-badge {
        display: inline-block;
        font-size: 0.65rem;
        letter-spacing: 0.35em;
        text-transform: uppercase;
        color: #c8ff50;
        border: 1px solid rgba(200,255,80,0.45);
        padding: 5px 18px;
        border-radius: 99px;
        margin-bottom: 2rem;
        opacity: 0;
        animation: tUp 0.6s ease 0.1s forwards;
      }

      .t-title {
        font-family: 'Noto Sans JP', sans-serif;
        font-weight: 900;
        font-size: clamp(3.5rem, 10vw, 7.5rem);
        line-height: 1.0;
        letter-spacing: -0.02em;
        color: #ffffff;
        text-align: center;
        width: 100%;
        opacity: 0;
        animation: tUp 0.7s ease 0.2s forwards;
      }
      .t-title .t-accent {
        color: #c8ff50;
        display: block;
        text-shadow: 0 0 40px rgba(200,255,80,0.6), 0 0 80px rgba(200,255,80,0.25);
      }

      .t-desc {
        margin-top: 1.75rem;
        font-size: clamp(0.85rem, 2vw, 1rem);
        color: rgba(240,240,240,0.5);
        line-height: 1.9;
        letter-spacing: 0.05em;
        text-align: center;
        opacity: 0;
        animation: tUp 0.7s ease 0.35s forwards;
      }

      .t-btn {
        margin-top: 2.5rem;
        display: inline-flex;
        align-items: center;
        gap: 10px;
        background: #c8ff50;
        color: #0a0a0a;
        font-weight: 900;
        font-size: 0.85rem;
        letter-spacing: 0.14em;
        text-transform: uppercase;
        text-decoration: none;
        padding: 15px 40px;
        border-radius: 3px;
        position: relative;
        overflow: hidden;
        opacity: 0;
        animation: tUp 0.7s ease 0.5s forwards;
        transition: transform 0.2s, box-shadow 0.2s;
      }
      .t-btn::before {
        content: '';
        position: absolute;
        inset: 0;
        background: rgba(255,255,255,0.28);
        transform: translateX(-110%) skewX(-15deg);
        transition: transform 0.4s;
      }
      .t-btn:hover::before { transform: translateX(110%) skewX(-15deg); }
      .t-btn:hover { transform: translateY(-3px); box-shadow: 0 12px 40px rgba(200,255,80,0.45); }

      @keyframes tUp {
        from { opacity: 0; transform: translateY(30px); }
        to   { opacity: 1; transform: translateY(0); }
      }

      /* ===== STATS ===== */
      .t-stats {
        background: #0f0f0f;
        border-top: 1px solid rgba(200,255,80,0.18);
        border-bottom: 1px solid rgba(200,255,80,0.18);
        padding: 1.75rem 2rem;
        display: flex;
        justify-content: center;
        align-items: center;
        gap: clamp(2rem, 8vw, 8rem);
        flex-wrap: wrap;
        width: 100vw;
        margin-left: calc(50% - 50vw);
      }
      .t-stat { text-align: center; }
      .t-stat-n {
        font-family: 'Oswald', sans-serif;
        font-size: 2.4rem;
        color: #c8ff50;
        line-height: 1;
        letter-spacing: 0.02em;
      }
      .t-stat-l {
        font-size: 0.65rem;
        letter-spacing: 0.22em;
        color: rgba(240,240,240,0.38);
        text-transform: uppercase;
        margin-top: 5px;
      }

      /* ===== CARDS ===== */
      .t-features {
        padding: 5rem 2rem;
        max-width: 1080px;
        margin: 0 auto;
        text-align: center;
      }
      .t-sec-badge {
        font-size: 0.65rem;
        letter-spacing: 0.3em;
        text-transform: uppercase;
        color: #c8ff50;
        margin-bottom: 0.75rem;
      }
      .t-sec-title {
        font-family: 'Noto Sans JP', sans-serif;
        font-weight: 900;
        font-size: clamp(1.8rem, 5vw, 3rem);
        line-height: 1.15;
        margin-bottom: 3rem;
        color: #f0f0f0;
      }
      .t-cards {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
        gap: 1px;
        background: rgba(200,255,80,0.1);
      }
      .t-card {
        background: #0d0d0d;
        padding: 2.25rem 1.75rem;
        text-align: left;
        position: relative;
        overflow: hidden;
        transition: background 0.25s;
      }
      .t-card:hover { background: #131313; }
      .t-card::after {
        content: '';
        position: absolute;
        bottom: 0; left: 0;
        height: 2px; width: 0;
        background: #c8ff50;
        transition: width 0.4s;
      }
      .t-card:hover::after { width: 100%; }
      .t-card-ico { font-size: 1.8rem; margin-bottom: 1rem; }
      .t-card-ttl {
        font-weight: 900;
        font-size: 1.05rem;
        color: #f0f0f0;
        margin-bottom: 0.6rem;
        letter-spacing: 0.03em;
      }
      .t-card-txt {
        font-size: 0.85rem;
        color: rgba(240,240,240,0.45);
        line-height: 1.85;
      }

      /* ===== CTA ===== */
      .t-cta-wrap {
        width: 100vw;
        margin-left: calc(50% - 50vw);
        padding: 0;
      }
      .t-cta {
        background: linear-gradient(130deg, #c8ff50 0%, #8dcc00 100%);
        border-radius: 0;
        padding: 3.5rem clamp(2rem, 8vw, 8rem);
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 2rem;
        flex-wrap: wrap;
        position: relative;
        overflow: hidden;
      }
      .t-cta::after {
        content: 'TENNIS';
        position: absolute;
        right: -10px; bottom: -28px;
        font-family: 'Oswald', sans-serif;
        font-size: 8rem;
        font-weight: 700;
        color: rgba(0,0,0,0.07);
        line-height: 1;
        pointer-events: none;
        letter-spacing: -0.02em;
      }
      .t-cta-h {
        font-weight: 900;
        font-size: clamp(1.5rem, 4vw, 2.2rem);
        color: #0a0a0a;
        line-height: 1.2;
      }
      .t-cta-p { color: rgba(0,0,0,0.5); margin-top: 0.4rem; font-size: 0.88rem; }
      .t-cta-btn {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        background: #0a0a0a;
        color: #c8ff50;
        font-weight: 900;
        font-size: 0.82rem;
        letter-spacing: 0.13em;
        text-transform: uppercase;
        text-decoration: none;
        padding: 14px 30px;
        border-radius: 3px;
        white-space: nowrap;
        transition: transform 0.2s, box-shadow 0.2s;
      }
      .t-cta-btn:hover { transform: translateY(-2px); box-shadow: 0 8px 24px rgba(0,0,0,0.3); }
    </style>

    <Header />
    <main>

      <!-- HERO -->
      <section class="t-hero">
        <canvas id="tennis-canvas"></canvas>
        <div class="t-ring t-ring-1"></div>
        <div class="t-ring t-ring-2"></div>
        <div class="t-netline"></div>

        <div class="t-content">
          <span class="t-badge">Tennis Practice Notes</span>
          <h1 class="t-title">
            テニス
            <span class="t-accent">練習メモ</span>
          </h1>
          <p class="t-desc">
            コートで気づいたこと、体の感覚、改善のヒントを<br />
            ひとつひとつ丁寧に記録していく。
          </p>
          <a href="/blog" class="t-btn">記事一覧を見る &nbsp;→</a>
        </div>
      </section>

      <!-- STATS -->
      <div class="t-stats">
        <div class="t-stat"><div class="t-stat-n">壁</div><div class="t-stat-l">を意識する</div></div>
        <div class="t-stat"><div class="t-stat-n">体幹</div><div class="t-stat-l">で打つ</div></div>
        <div class="t-stat"><div class="t-stat-n">捻転</div><div class="t-stat-l">を効かせる</div></div>
        <div class="t-stat"><div class="t-stat-n">脱力</div><div class="t-stat-l">から爆発へ</div></div>
      </div>

      <!-- FEATURES -->
      <section class="t-features">
        <p class="t-sec-badge">About This Blog</p>
        <h2 class="t-sec-title">練習で気づいたことを<br />まとめています</h2>
        <div class="t-cards">
          <div class="t-card">
            <div class="t-card-ico">🎾</div>
            <h3 class="t-card-ttl">フォームの感覚</h3>
            <p class="t-card-txt">打つ瞬間の体の使い方、力の入れ方・抜き方のリアルな記録。理論より感覚を大切に。</p>
          </div>
          <div class="t-card">
            <div class="t-card-ico">💡</div>
            <h3 class="t-card-ttl">気づきのメモ</h3>
            <p class="t-card-txt">練習中にふと気づいた発見を忘れないうちに記録。小さな気づきが大きな改善につながる。</p>
          </div>
          <div class="t-card">
            <div class="t-card-ico">📈</div>
            <h3 class="t-card-ttl">改善の記録</h3>
            <p class="t-card-txt">壁を意識する、体幹で打つ、捻転を効かせる。課題と取り組みを継続的に追っていく。</p>
          </div>
        </div>
      </section>

      <!-- CTA -->
      <div class="t-cta-wrap">
        <div class="t-cta">
          <div>
            <p class="t-cta-h">記事を読んで<br />一緒に上達しよう</p>
            <p class="t-cta-p">コートで使えるヒントが見つかるかも。</p>
          </div>
          <a href="/blog" class="t-cta-btn">記事一覧へ &nbsp;→</a>
        </div>
      </div>

    </main>
    <Footer />

    <script>
    (function() {
      const canvas = document.getElementById('tennis-canvas');
      if (!canvas) return;
      const ctx = canvas.getContext('2d');

      function resize() {
        canvas.width  = canvas.offsetWidth;
        canvas.height = canvas.offsetHeight;
      }
      resize();
      window.addEventListener('resize', resize);

      // ===== グリッド線 =====
      function drawGrid() {
        ctx.strokeStyle = 'rgba(255,255,255,0.04)';
        ctx.lineWidth = 1;
        const size = 60;
        for (let x = 0; x < canvas.width; x += size) {
          ctx.beginPath(); ctx.moveTo(x, 0); ctx.lineTo(x, canvas.height); ctx.stroke();
        }
        for (let y = 0; y < canvas.height; y += size) {
          ctx.beginPath(); ctx.moveTo(0, y); ctx.lineTo(canvas.width, y); ctx.stroke();
        }
      }

      // ===== ボールクラス =====
      class Ball {
        constructor() { this.reset(true); }
        reset(init) {
          this.r  = Math.random() * 18 + 10;
          this.x  = init ? Math.random() * canvas.width : -this.r * 2;
          this.y  = Math.random() * canvas.height;
          this.vx = Math.random() * 2.5 + 1.2;
          this.vy = (Math.random() - 0.5) * 2;
          this.rot = 0;
          this.rotSpeed = (Math.random() - 0.5) * 0.12;
          this.alpha = Math.random() * 0.5 + 0.3;
          this.glow = Math.random() * 20 + 10;
        }
        update() {
          this.x += this.vx;
          this.y += this.vy;
          this.rot += this.rotSpeed;
          if (this.x > canvas.width + this.r * 2) this.reset(false);
        }
        draw() {
          ctx.save();
          ctx.globalAlpha = this.alpha;
          ctx.translate(this.x, this.y);
          ctx.rotate(this.rot);

          // グロー
          const grd = ctx.createRadialGradient(0, 0, 0, 0, 0, this.r * 2.5);
          grd.addColorStop(0, `rgba(200,255,80,${this.alpha * 0.4})`);
          grd.addColorStop(1, 'rgba(200,255,80,0)');
          ctx.fillStyle = grd;
          ctx.beginPath();
          ctx.arc(0, 0, this.r * 2.5, 0, Math.PI * 2);
          ctx.fill();

          // ボール本体
          const ballGrd = ctx.createRadialGradient(-this.r*0.3, -this.r*0.3, 0, 0, 0, this.r);
          ballGrd.addColorStop(0, '#e2ff5a');
          ballGrd.addColorStop(1, '#7db800');
          ctx.fillStyle = ballGrd;
          ctx.beginPath();
          ctx.arc(0, 0, this.r, 0, Math.PI * 2);
          ctx.fill();

          // ストリング線（曲線）
          ctx.strokeStyle = 'rgba(255,255,255,0.55)';
          ctx.lineWidth = Math.max(1, this.r * 0.1);
          ctx.beginPath();
          ctx.arc(0, 0, this.r * 0.75, -0.6, 0.6);
          ctx.stroke();
          ctx.beginPath();
          ctx.arc(0, 0, this.r * 0.75, Math.PI - 0.6, Math.PI + 0.6);
          ctx.stroke();

          ctx.restore();
        }
      }

      // ===== トレイルクラス（残像） =====
      class Trail {
        constructor(ball) {
          this.x = ball.x; this.y = ball.y;
          this.r = ball.r * 0.5;
          this.alpha = ball.alpha * 0.4;
          this.life = 1;
        }
        update() { this.life -= 0.05; this.alpha *= 0.88; }
        draw() {
          if (this.life <= 0) return;
          ctx.save();
          ctx.globalAlpha = this.alpha;
          ctx.fillStyle = '#c8ff50';
          ctx.beginPath();
          ctx.arc(this.x, this.y, this.r * this.life, 0, Math.PI * 2);
          ctx.fill();
          ctx.restore();
        }
        get dead() { return this.life <= 0; }
      }

      // ===== ラケットクラス =====
      class Racket {
        constructor() { this.reset(); }
        reset() {
          this.x = -120;
          this.y = Math.random() * canvas.height * 0.6 + canvas.height * 0.2;
          this.speed = Math.random() * 3 + 2;
          this.swing = 0;
          this.swingDir = 1;
          this.alpha = 0.7;
        }
        update() {
          this.x += this.speed;
          this.swing += 0.06 * this.swingDir;
          if (Math.abs(this.swing) > 0.5) this.swingDir *= -1;
          if (this.x > canvas.width + 150) this.reset();
        }
        draw() {
          ctx.save();
          ctx.globalAlpha = this.alpha;
          ctx.translate(this.x, this.y);
          ctx.rotate(this.swing - 0.3);

          const scale = 1.2;

          // グリップ
          ctx.strokeStyle = '#888';
          ctx.lineWidth = 6 * scale;
          ctx.lineCap = 'round';
          ctx.beginPath();
          ctx.moveTo(0, 50 * scale);
          ctx.lineTo(0, 90 * scale);
          ctx.stroke();

          // シャフト
          ctx.strokeStyle = '#aaa';
          ctx.lineWidth = 4 * scale;
          ctx.beginPath();
          ctx.moveTo(0, 20 * scale);
          ctx.lineTo(0, 50 * scale);
          ctx.stroke();

          // ヘッド（楕円）
          ctx.strokeStyle = '#c8ff50';
          ctx.lineWidth = 4 * scale;
          ctx.shadowColor = 'rgba(200,255,80,0.6)';
          ctx.shadowBlur = 12;
          ctx.beginPath();
          ctx.ellipse(0, 0, 36 * scale, 48 * scale, 0, 0, Math.PI * 2);
          ctx.stroke();
          ctx.shadowBlur = 0;

          // ストリング縦
          ctx.strokeStyle = 'rgba(200,255,80,0.35)';
          ctx.lineWidth = 1;
          for (let i = -3; i <= 3; i++) {
            const xi = i * 10 * scale;
            const yTop = -Math.sqrt(Math.max(0, 1 - (xi/(36*scale))**2)) * 48 * scale;
            const yBot =  Math.sqrt(Math.max(0, 1 - (xi/(36*scale))**2)) * 48 * scale;
            ctx.beginPath(); ctx.moveTo(xi, yTop); ctx.lineTo(xi, yBot); ctx.stroke();
          }
          // ストリング横
          for (let i = -4; i <= 4; i++) {
            const yi = i * 10 * scale;
            const xLeft = -Math.sqrt(Math.max(0, 1 - (yi/(48*scale))**2)) * 36 * scale;
            const xRight = Math.sqrt(Math.max(0, 1 - (yi/(48*scale))**2)) * 36 * scale;
            ctx.beginPath(); ctx.moveTo(xLeft, yi); ctx.lineTo(xRight, yi); ctx.stroke();
          }

          ctx.restore();
        }
      }

      // ===== パーティクル（ヒットエフェクト） =====
      class Particle {
        constructor(x, y) {
          this.x = x; this.y = y;
          const angle = Math.random() * Math.PI * 2;
          const speed = Math.random() * 4 + 1;
          this.vx = Math.cos(angle) * speed;
          this.vy = Math.sin(angle) * speed;
          this.life = 1;
          this.r = Math.random() * 4 + 2;
          this.alpha = 1;
        }
        update() {
          this.x += this.vx; this.y += this.vy;
          this.life -= 0.04; this.alpha = this.life;
          this.vx *= 0.95; this.vy *= 0.95;
        }
        draw() {
          ctx.save();
          ctx.globalAlpha = Math.max(0, this.alpha);
          ctx.fillStyle = '#c8ff50';
          ctx.shadowColor = '#c8ff50';
          ctx.shadowBlur = 6;
          ctx.beginPath();
          ctx.arc(this.x, this.y, this.r, 0, Math.PI * 2);
          ctx.fill();
          ctx.restore();
        }
        get dead() { return this.life <= 0; }
      }

      // ===== 初期化 =====
      const balls    = Array.from({ length: 8 }, () => new Ball());
      const rackets  = [new Racket()];
      const trails   = [];
      const particles = [];
      let   frame    = 0;

      // ランダムでラケット追加
      setInterval(() => {
        if (rackets.length < 3) rackets.push(new Racket());
      }, 4000);

      // ===== メインループ =====
      function animate() {
        ctx.clearRect(0, 0, canvas.width, canvas.height);
        drawGrid();
        frame++;

        // トレイル更新
        trails.forEach(t => { t.update(); t.draw(); });
        trails.splice(0, trails.length, ...trails.filter(t => !t.dead));

        // ボール更新
        balls.forEach(ball => {
          if (frame % 3 === 0) trails.push(new Trail(ball));
          ball.update();
          ball.draw();

          // ラケットとの衝突チェック
          rackets.forEach(rac => {
            const dx = ball.x - rac.x;
            const dy = ball.y - rac.y;
            const dist = Math.sqrt(dx*dx + dy*dy);
            if (dist < 60) {
              for (let i = 0; i < 8; i++) particles.push(new Particle(ball.x, ball.y));
              ball.vx = Math.abs(ball.vx) * 1.5;
              ball.vy *= -1;
            }
          });
        });

        // ラケット更新
        rackets.forEach(rac => { rac.update(); rac.draw(); });

        // パーティクル更新
        particles.forEach(p => { p.update(); p.draw(); });
        particles.splice(0, particles.length, ...particles.filter(p => !p.dead));

        requestAnimationFrame(animate);
      }

      animate();
    })();
    </script>
  </body>
</html>
