---
import { SITE_TITLE } from '../consts';

// 今見ているページのURL
const pathname = Astro.url.pathname;

// 現在のページかどうか判定するヘルパー
const isActive = (href: string) => {
  if (href === '/') return pathname === '/';
  return pathname === href || pathname.startsWith(href + '/');
};
---

<header class="fd-header">
  <nav class="fd-nav">
    <!-- ブランドロゴ -->
    <a href="/" class="fd-brand">
      <span class="fd-dot" aria-hidden="true"></span>
      <span class="fd-brandText">{SITE_TITLE}</span>
    </a>

    <!-- メインナビ -->
    <ul class="fd-navList">
      <li>
        <a href="/" class={isActive('/') ? 'fd-navLink is-active' : 'fd-navLink'}>
          HOME
        </a>
      </li>
      <li>
        <a href="/blog" class={isActive('/blog') ? 'fd-navLink is-active' : 'fd-navLink'}>
          BLOG
        </a>
      </li>
      <li>
        <a href="/about" class={isActive('/about') ? 'fd-navLink is-active' : 'fd-navLink'}>
          ABOUT
        </a>
      </li>
      <li>
        <a href="/contact" class={isActive('/contact') ? 'fd-navLink is-active' : 'fd-navLink'}>
          CONTACT
        </a>
      </li>
    </ul>

    <!-- 右側のアクセントボタン -->
    <a href="/contact" class="fd-cta">
      <span class="fd-ctaDot" aria-hidden="true"></span>
      INQUIRY
    </a>
  </nav>
</header>

<style>
  /* ===== ヘッダー全体 ===== */
  .fd-header {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    background: rgba(10, 15, 10, 0.82);
    backdrop-filter: blur(14px) saturate(140%);
    -webkit-backdrop-filter: blur(14px) saturate(140%);
    border-bottom: 1px solid rgba(196, 255, 61, 0.18);
    box-shadow: 0 2px 24px rgba(0, 0, 0, 0.35);
  }

  .fd-nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 24px;
    padding: 14px 32px;
    max-width: 1400px;
    margin: 0 auto;
    font-family: "Helvetica Neue","Arial","Hiragino Kaku Gothic ProN","Yu Gothic",sans-serif;
  }

  /* ===== 左：ブランド ===== */
  .fd-brand {
    display: flex;
    align-items: center;
    gap: 10px;
    color: #ffffff;
    text-decoration: none;
    font-weight: 900;
    letter-spacing: 0.22em;
    font-size: 14px;
    text-transform: uppercase;
    white-space: nowrap;
  }
  .fd-dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: #c4ff3d;
    box-shadow: 0 0 12px #c4ff3d, 0 0 4px #c4ff3d;
    animation: fdDotPulse 2.4s ease-in-out infinite;
  }
  @keyframes fdDotPulse {
    0%, 100% { opacity: 1; transform: scale(1); }
    50% { opacity: 0.55; transform: scale(0.88); }
  }

  /* ===== 中央：ナビリスト ===== */
  .fd-navList {
    display: flex;
    gap: 34px;
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .fd-navLink {
    color: rgba(255, 255, 255, 0.72);
    text-decoration: none;
    font-size: 13px;
    letter-spacing: 0.18em;
    font-weight: 600;
    position: relative;
    padding: 8px 0;
    transition: color 0.2s ease;
    display: inline-block;
  }
  .fd-navLink:hover {
    color: #ffffff;
  }
  .fd-navLink.is-active {
    color: #c4ff3d;
  }
  .fd-navLink.is-active::after {
    content: '';
    position: absolute;
    left: 0;
    right: 0;
    bottom: 0;
    height: 2px;
    background: #c4ff3d;
    box-shadow: 0 0 8px rgba(196, 255, 61, 0.8);
    border-radius: 2px;
  }

  /* ===== 右：INQUIRYボタン ===== */
  .fd-cta {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 10px 20px;
    border: 1px solid #c4ff3d;
    color: #c4ff3d;
    border-radius: 999px;
